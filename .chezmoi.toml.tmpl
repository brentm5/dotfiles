{{- $use_secrets := promptBoolOnce . "use_secrets" "Use secrets from 1Password? (true/false)" -}}

sourceDir = "{{ .chezmoi.homeDir }}/.dotfiles"
progress = true

[data]
  github_user = "brentm5"
  use_secrets = {{ $use_secrets }}


{{ if lookPath "delta" -}}
[diff]
  pager = "delta"
{{ end -}}

{{ if lookPath "code" -}}
[edit]
    args    = ["-r", "--wait"]
    command = "code"
{{ end -}}