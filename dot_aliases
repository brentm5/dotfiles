# General
alias dot="chezmoi"
alias dotfiles="chezmoi cd"
alias md="marked"
alias l='ls'
alias c="cd ~/code"

# Unix
alias ll="ls -al"
alias ln="ln -v"
alias mkdir="mkdir -p"
alias ls="lsd"

alias killit="echo "🔥" && kill -s KILL"

alias matches="grep -qi"

# Shitty fixes
alias fix_dock="killall -Kill Dock"
alias fix-completions="rm ~/.zcompdump && exec zsh"

# git
alias gs="git status --short --branch"
alias gg="git log --graph"
alias gcm="git commit -m"

# Bundler
alias b="bundle"
alias be="bundle exec"

# Spotify
alias song="tmux-spotify-info"

# Pretty print the path
alias path='echo $PATH | tr -s ":" "\n"'

# Command to reload zsh
alias reload-zsh='source ${HOME}/.zshrc'

# Local LLM
alias llm="clai --chat-model ollama:gemma3:4b"
alias ask="llm q"
alias rask="llm -re q"

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local