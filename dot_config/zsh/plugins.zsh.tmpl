{{ $plugins := .zsh.plugins -}}
{{- $rootDir := .xdgDataDir -}}
# ZSH Plugins (If Any Installed)
{{ range $plugins.to_install -}}
{{ if all .name .source_file -}}
[[ -f {{ $rootDir }}/{{ $plugins.install_path }}/{{ .name }}/{{ .source_file }} ]] && source {{ $rootDir }}/{{ $plugins.install_path }}/{{ .name }}/{{ .source_file }}
{{ end -}}
{{ end -}}