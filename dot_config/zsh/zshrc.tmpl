{{ template "base-shell-environment.sh" . }}

# ZSH Plugins
[[ -f "${XDG_CONFIG_HOME}/zsh/plugins.zsh" ]] && source "${XDG_CONFIG_HOME}/zsh/plugins.zsh"

# extra files in ${XDG_CONFIG_HOME}/zsh?configs/pre , ${XDG_CONFIG_HOME}/zsh/configs , and ${XDG_CONFIG_HOME}/zsh/configs/post
# these are loaded first, second, and third, respectively.
_load_settings() {
  _dir="$1"
  if [ -d "$_dir" ]; then
    if [ -d "$_dir/pre" ]; then
      for config in "$_dir"/pre/**/*(N-.); do
        if [ ${config:e} = "zwc" ] ; then continue ; fi
        . $config
      done
    fi

    for config in "$_dir"/**/*(N-.); do
      case "$config" in
        "$_dir"/pre/*)
          :
          ;;
        "$_dir"/post/*)
          :
          ;;
        *)
          if [[ -f $config && ${config:e} != "zwc" ]]; then . $config
          fi
          ;;
      esac
    done

    if [ -d "$_dir/post" ]; then
      for config in "$_dir"/post/**/*(N-.); do
        if [ ${config:e} = "zwc" ] ; then continue ; fi
        . $config
      done
    fi
  fi
}
_load_settings "${XDG_CONFIG_HOME}/zsh/configs"

# Local config
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# aliases
[[ -f ~/.aliases ]] && source ~/.aliases

# Load environment secrets that are always loaded
[[ -f "${XDG_CONFIG_HOME}/zsh/secrets" ]] && source "${XDG_CONFIG_HOME}/zsh/secrets"

# Load secrets that can be loaded with `load-secrets` command
[[ -f $SECRETS_FILE ]] && source $SECRETS_FILE
