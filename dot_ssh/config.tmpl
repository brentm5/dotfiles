Host *
  IdentityAgent "${HOME}/.1password/agent.sock"

{{- if and .use_secrets (not .work_environment) }}
{{- range .ssh.hosts }}

Host {{ .name }}
    User {{ (onepasswordDetailsFields .op_id).username.value }}
    Hostname {{ (onepasswordDetailsFields .op_id).url.value }}
{{- if (onepasswordDetailsFields .op_id).port }}
    Port {{ (onepasswordDetailsFields .op_id).port.value }}
{{- end }}
{{- end }}
{{- end }}

Include {{ .xdgConfigDir }}/colima/ssh_config
